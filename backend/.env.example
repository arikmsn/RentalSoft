PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rentalsoft
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Demo user credentials (REQUIRED for seeding demo users)
# Set these env vars before running: npm run db:seed
#
# Required env vars:
ADMIN_PASSWORD=    # e.g. ADMINADMIN
MANAGER_PASSWORD=  # e.g. qazwsx123
TECH_PASSWORD=     # e.g. TECHAPP
TECH2_PASSWORD=    # e.g. TECHAPP
